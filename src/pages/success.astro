---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You - Fonte do Palheiro Estate" description="Thank you for your inquiry">
  <div class="success-page">
    <div class="success-content">
      <h1>Thank You</h1>
      <p>Your message has been sent successfully. We'll be in touch shortly.</p>
      <a href="/" class="btn">Return to Property</a>
    </div>
  </div>
</Layout>

<style>
  .success-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream);
    padding: 2rem;
  }
  .success-content {
    text-align: center;
    max-width: 500px;
  }
  h1 {
    font-family: var(--font-heading);
    font-size: 3rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  p {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .btn {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-white);
    padding: 1rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
  }
</style>
